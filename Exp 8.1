#include <iostream>
using namespace std;

class Node {
public:
    int data;
    Node* next;
};

Node* front = NULL;
Node* rear = NULL;

// Enqueue Operation
void enqueue(int value) {
    Node* newNode = new Node();
    newNode->data = value;
    newNode->next = NULL;

    if (rear == NULL) {
        front = rear = newNode;
    }
    else {
        rear->next = newNode;
        rear = newNode;
    }

    cout << value << " inserted into queue\n";
}

// Dequeue Operation
void dequeue() {
    if (front == NULL) {
        cout << "Queue Underflow\n";
    }
    else {
        Node* temp = front;
        cout << temp->data << " deleted from queue\n";

        front = front->next;

        if (front == NULL)
            rear = NULL;

        delete temp;
    }
}

// Display Operation
void display() {
    if (front == NULL) {
        cout << "Queue is Empty\n";
    }
    else {
        Node* temp = front;

        cout << "Queue Elements:\n";

        while (temp != NULL) {
            cout << temp->data << " ";
            temp = temp->next;
        }

        cout << endl;
    }
}

int main() {
    int choice, value;

    do {
        cout << "\n1.Enqueue\n2.Dequeue\n3.Display\n4.Exit\n";
        cout << "Enter Choice: ";
        cin >> choice;

        switch(choice) {
            case 1:
                cout << "Enter value: ";
                cin >> value;
                enqueue(value);
                break;

            case 2:
                dequeue();
                break;

            case 3:
                display();
                break;

            case 4:
                cout << "Exit";
                break;

            default:
                cout << "Invalid Choice";
        }

    } while(choice != 4);

    return 0;
}
